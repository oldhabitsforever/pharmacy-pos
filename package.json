    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.447.0",
    "next": "14.2.23",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.53.0",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
